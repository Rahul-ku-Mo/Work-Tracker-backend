// Activity Log model to track all changes made on a card (updates, etc.)
model ActivityLog {
  id          Int      @id @default(autoincrement())
  cardId      Int
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  action      String // Describe the action, e.g., "Updated description", "Moved card", etc.
  performedBy String // User ID of who performed the action
  createdAt   DateTime @default(now())
  Board       Board?   @relation(fields: [boardId], references: [id])
  boardId     Int?
}

// Label model
model Label {
  id        Int      @id @default(autoincrement())
  name      String
  color     String
  cardId    Int
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())
}

// Video Meeting model to store information about meetings and transcripts
model VideoMeeting {
  id            Int      @id @default(autoincrement())
  ticketId      Int
  ticket        Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  participants  User[]   @relation("videoMeetingParticipants")
  meetingUrl    String // URL of the video meeting
  transcriptUrl String? // URL of the transcript file
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Pricing Plan model
model PricingPlan {
  id           String         @id @default(uuid())
  name         String
  teamSize     Int
  price        Float
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  Organization Organization[]
}

// Payment model
model Payment {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  amount         Float
  paymentDate    DateTime     @default(now())
  status         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
