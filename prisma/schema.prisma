generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User roles as enum
enum Role {
  ADMIN
  TEAM_MEMBER
  TEAM_LEAD
}

enum STATUS {
  ONLINE
  OFFLINE
}

// User model
model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  name           String
  imageUrl       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  role           Role
  payments       Payment?
  userStatus     UserStatus
  Organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  team           Team[]        @relation(fields: [teamId], references: [id])
  teamId         String? //Admin can be a team lead
}

model UserStatus {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  status    STATUS
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Organization model
model Organization {
  id            String      @id @default(uuid())
  name          String
  buyer         User        @relation(fields: [buyerId], references: [id])
  buyerId       String
  teams         Team[]
  pricingPlanId String
  pricingPlan   PricingPlan @relation(fields: [pricingPlanId], references: [id])
}

model Team {
  id          String   @id @default(uuid())
  name        String
  teamLead    User     @relation("teamLeads", fields: [teamLeadId], references: [id])
  teamLeadId  String
  teamMembers User[]   @relation("members")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Board model
model Kanban {
  id            String         @id @default(uuid())
  name          String
  userId        String //user who created the kanban board(team_lead)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teamId        String
  team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  progression   Progression[]
  imageId       String
  imageThumbUrl String
  imageFullUrl  String
  imageLinkHTML String
  imageUserName String
  ActivityLog   ActivityLog[]
  videoMeetings VideoMeeting[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Column model
model Progression {
  id        String   @id @default(uuid())
  name      String
  tickets   Ticket[]
  KanbanId  String
  Kanban    Kanban   @relation(fields: [KanbanId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Card model (Updated to include activity logs and meetings)
model Ticket {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
  ProgressionId String
  Progression   Progression   @relation(fields: [ProgressionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  assignee      User?         @relation("assignee")
  dueDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  label         Label[]
  connection    Connection[]
  attachments   String[]
  // videoMeetings videoMeetings
}

model Connection {
  id       String @id @default(uuid())
  githubId String
  googleId String
  gitlabId String
}

